{
  "name": "erp-autoparts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -n vite,worker -c cyan,magenta \"npm run dev\" \"npm run worker\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "worker": "wrangler dev --port 8787",
    "db:list": "wrangler d1 list",
    "db:export:remote": "wrangler d1 export erp-db --remote --output=./d1-mirror-erp.sql",
    "db:export:local": "wrangler d1 export erp-db --local --output=./local-backup.sql",
    "db:import:local": "wrangler d1 execute erp-db --local --file=./d1-mirror-erp.sql",
    "db:migrate:local": "wrangler d1 execute erp-db --local --file=./sql/schema.sql",
    "db:migrate:remote": "wrangler d1 execute erp-db --remote --file=./sql/schema.sql"
  },
  "dependencies": {
    "firebase": "^12.12.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1",
    "wrangler": "^4.84.0"
  }
}
