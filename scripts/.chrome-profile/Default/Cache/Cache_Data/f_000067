<script>
	document.addEventListener('DOMContentLoaded', () => {
	    const tooltip = document.getElementById('tooltip');

	    // 为每个 input 添加事件
	    document.querySelectorAll('td input[type="text"]').forEach(input => {
	        input.addEventListener('mouseover', (event) => {
	            const td = event.target.closest('td'); // 获取所在单元格
	            tooltip.textContent = event.target.value; // 显示输入框的值
	            const rect = td.getBoundingClientRect(); // 获取单元格位置

                const iframeScrollTop = document.documentElement.scrollTop || document.body.scrollTop;
                const iframeScrollLeft = document.documentElement.scrollLeft || document.body.scrollLeft;

                console.log(`iframe 内部滚动量 - scrollTop: ${iframeScrollTop}, scrollLeft: ${iframeScrollLeft}`);


	            console.log("tooltip", td, rect);
	            console.log("tooltip.textContent", tooltip.textContent);

	            if (tooltip.textContent != '') {
	                // 设置工具提示的位置
	                tooltip.style.left = `${iframeScrollLeft + rect.left + 50}px`;
	                tooltip.style.top = `${iframeScrollTop + rect.top + 0}px`;
	                tooltip.style.display = 'block';
                    tooltip.style.opacity = '1';
	                
	                input.addEventListener('mouseout', () => {
	                    tooltip.style.opacity = '0';
	                    tooltip.style.display = 'none';
	                });
	            }

	        });
	    });
	});
</script>


