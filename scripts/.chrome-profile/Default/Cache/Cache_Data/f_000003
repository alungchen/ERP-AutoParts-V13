    function SetTableTrKeyNavigate(TableID , TextBoxID , func1 , func2)
    {
        var $table = $j(TableID);
        var $TextBox = $j(TextBoxID);
        var $tr = $table.find("tbody").find("tr");
        var iMaxRow = $tr.length;
        
        $tr.each(function (row, obj) {
            var $row = $j(this);
            var ClassName = "TrKeyNavigate_%row%";
            
            ClassName = ClassName.ReplaceAll("%row%", row);
            
            $row.attr("ThisRow", row);
            $row.attr("iMaxRow", iMaxRow);
            $row.addClass(ClassName);
        });
        

        
        $table.attr("TextBoxID", TextBoxID);
        $TextBox.attr("TableID", TableID);
        
        $table.click(function () {
            var $this = $j(this);
            var FocusID = $this.attr("TextBoxID");
            var $toFocus = $j(FocusID);
            var $toFocus_Parent = $toFocus.parent();
            var $this_tr = $this.find("tbody").find(".ui-state-active");
            var tr_position = $this_tr.position();
            
            $toFocus_Parent.css("position", "absolute");
            $toFocus_Parent.css("top" , tr_position.top + "px");
            $toFocus_Parent.css("left", "0px");
            $toFocus.focus();
        });
        
        $TextBox.keydown(function (e) {
            var $this = $j(this);
            var TargetID = $this.attr("TableID");
            var $target = $j(TargetID);
            var $this_tr = $target.find("tbody").find(".ui-state-active");
            var code = null;
            var ThisRow = 0;
            var iMaxRow = 0;
            var ClassName = "TrKeyNavigate_%row%";
            
            var $toFocus_Parent = $this.parent();
            var tr_position = $this_tr.position();
            
            $toFocus_Parent.css("position", "absolute");
            $toFocus_Parent.css("top" , tr_position.top + "px");
            $toFocus_Parent.css("left", "0px");
            $this.focus();
            
            if (tr_position.top + $this_tr.height() > $j(window).height() + $j(window).scrollTop())
            {
                $j(window).scrollTop(tr_position.top + $this_tr.height() + $this_tr.height() - $j(window).height());
            }
            
            if (tr_position.top < $j(window).scrollTop() + $this_tr.height())
            {
                //alert (tr_position.top + ", " + $this_tr.height() + ", " + $j(window).scrollTop() + ", " + $j(window).height());
                $j(window).scrollTop(tr_position.top - $this_tr.height());
            }
            //$j(window).scrollTop(tr_position.top);
            
            if ($this_tr.length == 0)
            {
                $target.find("tbody").find("tr").first().click();
                $this_tr = $target.find("tbody").find(".ui-state-active");
                
                if ($this_tr.length == 0)
                    return;
            }
            
            ThisRow = parseInt($this_tr.attr("ThisRow"));
            iMaxRow = parseInt($this_tr.attr("iMaxRow"));
            
            if (window.event) { e = window.event; }
            code = (e.keyCode ? e.keyCode : e.which); 
            
            //alert(e.shiftKey);
            //alert(e.which);
            
            switch (code)
            {
                case 38:
                    if (ThisRow == 0)
                    {
                        func1();
                        return;
                    }
                    ThisRow = ThisRow - 1
                    break;
                    
                case 40:
                    if (ThisRow == (iMaxRow-1))
                    {
                        func2();
                        return;
                    }
                    ThisRow = ThisRow + 1
                    break;
                default:
                    return;
            }
            
            ClassName = ClassName.ReplaceAll("%row%", ThisRow);
            
            $j(TableID + " ." + ClassName).click();
            return (false);
        });
    }

    function SetTableInputKeyNavigate( TableID , ele_row_col_id , func1 , func2 , func3 )
    {
        var $table = $j(TableID);
        var $row_col = $j(ele_row_col_id);
        var $tr = $table.find("tbody").find("tr");
        var iMaxRow = $tr.length;
        
        $tr.each(function (row, obj) {
            var $row = $j(this);
            var $input = $row.find("input:text:not([navigate_ignore='1'])");
            var iMaxCol = $input.length;
            
            $row.attr("ThisRow", row);

            $input.each(function (col, obj) {
                var $text = $j(this);
                var ClassName =  TableID + '_' + 'InputKeyNavigate_%row%_%col%';
                
                ClassName = ClassName.ReplaceAll("#", '');
                ClassName = ClassName.ReplaceAll("%row%", row);
                ClassName = ClassName.ReplaceAll("%col%", col);
                
                $text.attr("ThisRow", row);
                $text.attr("ThisCol", col);
                $text.attr("iMaxRow", iMaxRow);
                $text.attr("iMaxCol", iMaxCol);
                
                $text.addClass(ClassName);
            });
                        
            $input.keydown(function (e) {
                var $this = $j(this);
                var $target = null;
                var code = null;
                var ThisRow = parseInt($this.attr("ThisRow"));
                var ThisCol = parseInt($this.attr("ThisCol"));
                var iMaxRow = parseInt($this.attr("iMaxRow"));
                var iMaxCol = parseInt($this.attr("iMaxCol"));
                var ClassName = TableID + '_' + 'InputKeyNavigate_%row%_%col%';
                var this_value = $this.val();


                ClassName = ClassName.ReplaceAll("#", '');
                if (window.event) { e = window.event; }
                code = (e.keyCode ? e.keyCode : e.which); 
                
                //alert(e.shiftKey);
                //alert(e.which);
                    
                switch (code)
                {
                    case 27:
                            func3();
                            return;
                            break;

                    case 13:
                        if ($this.attr('stop_key_navigate') == '1')
                            return (false);

                        if (e.shiftKey == true)
                        {
                            if ($this.attr("NavigateLeftStop") == "1")
                                return (true);
                                
                            if (ThisCol == 0) {
                                //ThisCol = iMaxCol - 1;
                                if (ThisRow == 0)
                                {                                   
                                    func1();
                                    return;
                                }
                                ThisRow = ThisRow - 1;
                                ThisCol = parseInt($j( '.' + TableID.ReplaceAll("#", '') + '_' + 'InputKeyNavigate_' + ThisRow + '_0' ).attr('imaxcol')) - 1;
                            }
                            else
                                ThisCol = ThisCol - 1;
                        }
                        else if (e.ctrlKey == true) 
                        {
                             do_ctrl_enter_event($this);
                        }
                        else
                        {
                            if ($this.attr("NavigateRightStop") == "1")
                                return (true);
                                
                            if (ThisCol == iMaxCol -1) {
                                ThisCol = 0;
                                if (ThisRow == (iMaxRow-1))
                                {
                                    func2();
                                    return;
                                }
                                ThisRow = ThisRow + 1;
                            }
                            else
                                ThisCol = ThisCol + 1;
                        }
                        break;
                    
                    case 38:
                        if ($this.attr('stop_key_navigate') == '1')
                            return (false);

                        if ($this.attr("NavigateUpStop") == "1")
                            return (true);
                                
                        if (ThisRow == 0)
                        {                                   
                            func1();
                            return;
                        }
                        ThisRow = ThisRow - 1;
                        break;
                        
                    case 40:
                        if ($this.attr('stop_key_navigate') == '1')
                            return (false);

                        if ($this.attr("NavigateDownStop") == "1")
                            return (true);
                            
                        if (ThisRow == (iMaxRow-1))
                        {
                            func2();
                            return;
                        }
                        ThisRow = ThisRow + 1;
                        break;
                        
                    default:
                        return;
                }
                
                ClassName = ClassName.ReplaceAll("%row%", ThisRow);
                ClassName = ClassName.ReplaceAll("%col%", ThisCol);
                $row_col.attr("ThisRow" , ThisRow);
                $row_col.attr("ThisCol" , ThisCol);
                
                $target = $j(TableID + " ." + ClassName);
                $this.blur();
                $target.focus();
                $target.parent().parent().click();
                return (false);
            });
        });
    }

