				if (id != -1)
				{
					_ele = _element[id];
					_ele.checked = true;
				}
				break;
				
			case 'checkbox':
				var buf = _value.split(",")
			
				for(var i = 0; i < _element.length; i++)
				{
					_ele = _element[i];
					
					_ele.checked = false;
					
					for (var j = 0; j < buf.length; j++)
						if (_ele.value == buf[j])
						{
							_ele.checked = true;
							break;
						}
				}
				break;

			default:
		}
	}
	catch (e)
	{
		return ("err");
	}
}



