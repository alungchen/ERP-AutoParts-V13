    function url_to_post_data(str_url)
    {
        var str_PageName = "";
        var str_QueryString = "";
        var params = null;
        var dt = new DataTable;
        
        with (dt)
        {
            create("Name,Value".split(",") , null ,0);
            
            str_PageName = str_url.split("?")[0];
            
            AddNewRow();
            setValueByRow(0, "Name", "PageName");
            setValueByRow(0, "Value", str_PageName);
        
            if (str_url.indexOf("?") != -1)
                str_QueryString = str_url.split("?")[1];
                
            if (str_QueryString == "")
                return (dt);
            
            params = str_QueryString.split("&");
            
            for (var i = 0; i<params.length; i++)
            {
                AddNewRow();
                setValueByRow(i+1, "Name", unescape(params[i].split("=")[0]));
                setValueByRow(i+1, "Value", unescape(params[i].split("=")[1]));
            }
            
            return (dt);
        
        } 
    }
    
