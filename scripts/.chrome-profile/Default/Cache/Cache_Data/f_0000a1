            var val = ui.item.label;

            if (val.indexOf(" -- ") != "-1") {
                val = val.split(" -- ")[1];
            }

            $this.val(val).change();
        });

        var str_id = $this.attr("KeyValue");
        var old_value = $this.attr("old_value");

        var NewValue = $this.val();

        SetObjectInfo(ThisPartKeyInfo, "id", str_id, "CHNAME_LABLE", NewValue)
        SetObjectInfo(ThisPartKeyInfo, "id", str_id, "CHNAME_ID", fieldvalue)
        //            console.log("OldValue=" + OldValue);
        //            console.log("NewValue=" + NewValue);

        if ($this.attr("disupdate") == "1") {
            alertify.error("變更沒獲得授權!!!")
        }
        else {
            var list = FindObject(ThisPartKeyInfo, "CHNAME_LABLE", old_value);
            if (list.length != 0) {
                var $btn = $j("#btn_sync_chname");
                $btn.show();
                $btn.attr("KeyValue", str_id);
                $btn.attr("old_value", old_value);
                $btn.attr("NewValue", NewValue);
                $btn.attr("CHNAME_ID", fieldvalue);

                alertify.success("有相同內容的品名，可以同步!!!");
            }
        }


    }

