<script type="text/javascript">
    function TdAutoChangeWidth($items) {
        $items.addClass("CursorPointer");

        $items.click(function () {
            var $this = $j(this);
            var $input = $this.find("input");

            if ($input.length > 0) {
                return (true);
            }
            //console.log("TdAutoChangeWidth click", $this, $this.hasClass("width500"));
            if ($this.hasClass("width500")) {
                //console.log("removeClass('width500')");
                $this.removeClass("width500");
            }
            else {
                //console.log("addClass('width500')");
                $this.addClass("width500");
            }
        });
    }
</script> 

