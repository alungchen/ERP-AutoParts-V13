        var $target = $j(TargetID);
        var $this_tr = $target.find("tbody").find(".ui-state-active");

//        //console.log("set_auto_scroll_div TableID ", TableID);
//        //console.log("set_auto_scroll_div TextBoxID ", TextBoxID);
//        //console.log("set_auto_scroll_div DisplayID ", DisplayID);
//        //console.log("set_auto_scroll_div TargetID ", TargetID);

        ThisRow = parseInt($this_tr.attr("ThisRow"));
        iMaxRow = parseInt($this_tr.attr("iMaxRow"));

//        //console.log("set_auto_scroll_div ThisRow ", ThisRow);
//        //console.log("set_auto_scroll_div iMaxRow ", iMaxRow);

        ClassName = ClassName.ReplaceAll("%row%", ThisRow);
//        //console.log("set_auto_scroll_div ClassName ", ClassName);

        var $TR = $j(TableID + " ." + ClassName);
        var iScrollTo = $j($j(TableID + " tr")[ThisRow]).position().top - $j($j(TableID + " tr")[0]).position().top;
        var iScrollTop = $j(DisplayID).scrollTop();
        var iHeight = $j(DisplayID).height();
        var iTrHeight = $TR.height();
//        
//        //console.log("set_auto_scroll_div iScrollTo=" + iScrollTo);
//        //console.log("set_auto_scroll_div iScrollTop=" + iScrollTop);
//        //console.log("set_auto_scroll_div iHeight=" + iHeight);
//        //console.log("set_auto_scroll_div iTrHeight=" + iTrHeight);

        if ((iScrollTo + iTrHeight * 2) - iScrollTop >= iHeight) {
            $j(DisplayID).scrollTop(iScrollTo);
        }

        if (iScrollTop >= iScrollTo + iTrHeight) {
            //iScrollTo = 0;
            iScrollTo = iScrollTop - iHeight + iTrHeight;
            //iScrollTo = $j($j("#DataGridDetail tr")[ThisRow]).position().top - $j($j("#DataGridDetail tr")[0]).position().top;
            $j(DisplayID).scrollTop(iScrollTo);
        }
    }

