    function get_主資料(str_id) {
        var dt = new DataTable();
        var ApiUrl = "/car2009/api/get_主資料/";

        $j.ajax(
            {
                url : ApiUrl
                , cache: false
                , global : false
                , type : "POST"
                , data : {
                            "id": str_id
                        }
                , dataType : "json"
                , async : false
                , success : function(resp){
                    var list = resp.ReturnValue.list;

                    dt.ImportJsonArray(list);

                }
            }
        )

        return dt;
    }

