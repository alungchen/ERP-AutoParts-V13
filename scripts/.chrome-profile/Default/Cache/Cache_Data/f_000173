        var mappings = outside_data_mapping_list.split(",");

        if (data.trim() == '') {
            alert("沒有資料!!!");
            return (false);
        }

        $dsp.html("");

        result.push("<table width='100%'>");
        result.push("<tr>");
        for (var i = 0; i < fields.length; i++)
        {
            result.push("<td>");
            result.push(fields[i]);
            result.push("</td>");
        }
        result.push("</tr>");
        result.push("<tr>");
        for (var i = 0; i < fields.length; i++)
        {
            result.push("<td>");
            result.push(create_mapping_select(mappings , "outside_data_mapping_" + fields[i]));
            result.push("</td>");
        }
        result.push("</tr>");
        result.push("</table>");

        $dsp.html(result.join("\n"));
    }

    function create_mapping_select(mappings , name) {
        var result = new Array();

        result.push("<select name=\"" + name + "\" id=\"" + name + "\" >");

        for (var i = 0; i < mappings.length; i++) {
            result.push("<option value=\"" + mappings[i] + "\">" + mappings[i] + "</option>");
        }
        result.push("</select>");

        return(result.join("\n"));
    }

