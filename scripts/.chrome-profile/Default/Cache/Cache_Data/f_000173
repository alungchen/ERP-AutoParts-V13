    function do_inquiry_add() {
        var partsid = $j('#DataGridDetail tbody .ui-state-active').attr("partsid");
        var sup_id = $j('#ele_inquiry_廠商_id').val();
        var price = $j('#ele_inquiry_price').val();
        var note = $j('#ele_inquiry_note').val();
        var ApiUrl = "/car2009/api/inquiry_add/";

        if (partsid.trim() == "") {
            alertify.error("沒對應到零件資料!!!");
            return (false);
        }

        if (sup_id.trim() == "") {
            alertify.error("沒廠商資料!!!");
            return (false);
        }

        if (price.trim() == "") {
            alertify.error("沒單價!!!");
            return (false);
        }

        $j.ajax({
            url: ApiUrl
                , cache: false
                , global: false
                , type: "POST"
                , data: {
                    "partsid": partsid
                    , "sup_id": sup_id
                    , "price":  price
                    , "note":  note
                }
                , dataType: "json"
                , async: true
                , success: function(resp) {
                    if (resp.Code == "1") {
                        alertify.error(resp.Message);
                    }
                    else {
                        alertify.success(resp.Message);
                        $j('#DataGridDetail tbody .ui-state-active').click();
                    }
                }
        })
    }

