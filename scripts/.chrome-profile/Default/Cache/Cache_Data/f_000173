    function outside_data_column_mapping() {
        var data = $$GV("ele_outside_data");
        var row_data = data.split("\n")[0].rp("\r", "");
        var fields = row_data.rp(" ", "").split("\t");
        var $dsp = $j("#outside_data_field_list");
        var result = new Array();
