    function CheckHasBom(str_id) 
    {
        var ApiUrl = "/car2009/api/PartsBOM_CheckHasBom/";
        var HasBom = true;

        $j.ajax({
            url : ApiUrl
            , cache: false
            , global : false
            , type : "POST"
            , data : {
                        "str_id": str_id  
                    }
            , dataType : "json"
            , async : false
            , success :  function (resp) {
                if (resp.Code != '0') {
                    alertify.error(resp.Message);
                    HasBom = false;
                    return (false);
                }

                if (resp.ReturnValue.HasBom == "1") {
                    HasBom = true;
                    alertify.success(resp.Message);
                }
                else {
                    HasBom = false;
                }
            }
        });

        return (HasBom);
    }

