    function sys_merge_select2(dt_data, id, merge_id, merge_info) {
        var merge_mode = get_element_value('radio_merge');
//        //console.log("merge_id", merge_id);
//        //console.log("merge_info", merge_info);
//        //console.log("merge_mode", merge_mode);

        var dt = dt_data.getSearchDataTable("id", id);

        for (var col = 0; col < dt.getFieldCount(); col++) {
