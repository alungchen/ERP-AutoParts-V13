	    document.querySelectorAll('td input[type="text"]').forEach(input => {
	        input.addEventListener('mouseover', (event) => {
	            const td = event.target.closest('td'); // 获取所在单元格
	            tooltip.textContent = event.target.value; // 显示输入框的值
	            const rect = td.getBoundingClientRect(); // 获取单元格位置

                const iframeScrollTop = document.documentElement.scrollTop || document.body.scrollTop;
