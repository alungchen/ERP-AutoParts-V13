<script type="text/javascript">
    function TdAutoChangeWidth($items) {
        $items.addClass("CursorPointer");

        $items.click(function () {
            var $this = $j(this);
            var $input = $this.find("input");

            if ($input.length > 0) {
                return (true);
            }
            //console.log("TdAutoChangeWidth click", $this, $this.hasClass("width500"));
            if ($this.hasClass("width500")) {
                //console.log("removeClass('width500')");
                $this.removeClass("width500");
            }
            else {
                //console.log("addClass('width500')");
                $this.addClass("width500");
            }
        });
    }
</script> 

<script>
    ModuleName = "";
    SubModuleName = "";

    $j(function () {

        TdAutoChangeWidth($j("#DataGridDetail thead td"));

    });

    $j(function () {
        if (typeof (parent.parent.location.href) != "undefined") {
            var tmp = parent.parent.location.href.split("/");

            if (tmp.length >= 2)
                ModuleName = tmp[tmp.length - 2];
            else
                ModuleName = tmp[tmp.length - 1];
        }

        if (typeof (parent.location.href) != "undefined") {
            var tmp = parent.location.href.split("/");

            if (tmp.length >= 2)
                SubModuleName = tmp[tmp.length - 2];
            else
                SubModuleName = tmp[tmp.length - 1];
        }

        $j("#ModuleName").text(ModuleName);
        $j("#SubModuleName").text(SubModuleName);

        switch (ModuleName.toLowerCase()) {
            case "parts_query":
                HideButton();
                break;

            default:
                ShowButton();
                break;
        }

        switch (SubModuleName.toLowerCase()) {
            case "cart":
                ShowButton();
                break;
        }
    });

    $j(function () {
        主資料ID = "";
        var $target = $j(".主資料");
