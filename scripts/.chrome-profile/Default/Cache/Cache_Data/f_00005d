    function 複製_零件副檔() {
        SetTokenData("PartKey_Info", JSON.stringify(ThisPartKeyInfo));

        alertify.success("已經複製 適用資料...");
    }

    function 貼上_零件副檔() {
        var Value = GetTokenData("PartKey_Info");

        if (Value == "") {
            alert("沒有來源 適用資料 !!!");
        }
        else {
            $j("#div_貼上").show();

            var $dsp = $j("#Display_Partkey_Source");
            var data_template = $j("#tmpl-Partkey_Source").html();
            var data_list = JSON.parse(Value);

            $dsp.html("");

            DataAppender($dsp, data_list, data_template);

            
        }
    }

    function GetAllChkItems() {
        var id_list = new Array();
        var $items = $j(".chk_Selected");

        $items.each(function () {
            var $this = $j(this);
            var id = $this.attr("value");

            id_list.push(id);
        });

        return (id_list);
    }

    function Select_All() {
        var chk = $$GV("chk_SelectAll");
        //console.log("chk", chk);
        if (chk == "1") {
            var id_list = GetAllChkItems();
            //console.log("id_list", id_list);
            $$SV("chk_Selected", id_list.join(","));
        }
        else {
            $$SV("chk_Selected", "");
        }
    }

    function Select_chk_item() {
        var all_items = GetAllChkItems();
        var selected_items = $$GV("chk_Selected");

        if (all_items == selected_items) {
            $$SV("chk_SelectAll", "1")
        }
        else {
            $$SV("chk_SelectAll", "")
        }
    }

    function partkey_ReplaceAll() {
        var id_list = $$GV("chk_Selected");

        var ApiUrl = "/car2009/api/partkey_ReplaceAll/";
        var partkeyId = ThisPartKeyInfo[0]["零件主檔ID"];

        $j.ajax(
