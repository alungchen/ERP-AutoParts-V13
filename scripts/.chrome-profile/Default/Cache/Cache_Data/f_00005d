	            if (tooltip.textContent != '') {
	                // 设置工具提示的位置
	                tooltip.style.left = `${iframeScrollLeft + rect.left + 50}px`;
	                tooltip.style.top = `${iframeScrollTop + rect.top + 0}px`;
	                tooltip.style.display = 'block';
                    tooltip.style.opacity = '1';
	                
	                input.addEventListener('mouseout', () => {
