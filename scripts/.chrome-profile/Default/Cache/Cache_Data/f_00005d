    $j(function () {

        TdAutoChangeWidth($j("#DataGridDetail thead td"));

    });

    $j(function () {
        if (typeof (parent.parent.location.href) != "undefined") {
            var tmp = parent.parent.location.href.split("/");

            if (tmp.length >= 2)
                ModuleName = tmp[tmp.length - 2];
            else
                ModuleName = tmp[tmp.length - 1];
        }

        if (typeof (parent.location.href) != "undefined") {
            var tmp = parent.location.href.split("/");

            if (tmp.length >= 2)
                SubModuleName = tmp[tmp.length - 2];
            else
                SubModuleName = tmp[tmp.length - 1];
        }

        $j("#ModuleName").text(ModuleName);
        $j("#SubModuleName").text(SubModuleName);

        switch (ModuleName.toLowerCase()) {
            case "parts_query":
                HideButton();
                break;

            default:
                ShowButton();
                break;
        }

        switch (SubModuleName.toLowerCase()) {
            case "cart":
                ShowButton();
                break;
        }
    });

    $j(function () {
        主資料ID = "";
        var $target = $j(".主資料");
        //console.log("$target", $target);

        $target.each(function () {
            var $this = $j(this);
            var 主資料 = $this.attr("主資料");
            var KeyValue = $this.attr("KeyValue");

            if (主資料 == "1") {
                主資料ID = KeyValue;

                //console.log("主資料ID", 主資料ID);

                return (false);
            }
        });

        $$SV("ele_detail_主資料", 主資料ID);
    });

    function ShowButton() {
        $j(".Replacement").show();
    }

    function HideButton() {
        $j(".Replacement").hide();
    }

    function Replacement(id) {
        if (SubModuleName.toLowerCase() == "cart") {
            parent.Replacement(id);
        }
        else {
            parent.parent.Replacement(id);
        }
    }

    function Replacement_Realno(id) {
        if (SubModuleName.toLowerCase() == "cart") {
            parent.Replacement_Realno(id);
        }
        else {
            parent.parent.Replacement_Realno(id);
        }
    }

    function Update零件副檔(KeyName, KeyValue, FieldName, FieldValue) {
        var ApiUrl = "/car2009/api/Update零件副檔/";

        $j.ajax(
            {
                url: ApiUrl
                , cache: false
                , global: false
                , type: "POST"
                , data: {
                    "KeyName": KeyName
                    , "KeyValue": KeyValue
                    , "FieldName": FieldName
                    , "FieldValue": FieldValue
                }
                , dataType: "json"
                , async: false
                , success: Update零件副檔_finish
            }
        )
    }

