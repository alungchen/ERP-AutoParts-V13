function StringBuilder()
{
	this._buf = new Array();
	
	this.init = function ()
	{
		this._buf = new Array();
	}
	
	this.Append = function (str)
	{
		this._buf.push(str);
	}
	
	this.replace = function (str_target, str)
	{
		for (var i = 0; i < this._buf.length; i++)
			this._buf[i] = this._buf[i].ReplaceAll(str_target, str);
	}
	
	this.ToString = function ()
	{
		return (this._buf.join(""));
	}
}


