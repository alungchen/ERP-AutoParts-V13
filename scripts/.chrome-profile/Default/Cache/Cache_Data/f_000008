    function TextBox_KeyEvent($target, keycode, func) {
        $target.keydown(function(e){
            var $this = $j(this);
            var code = 0;

            if (window.event) { e = window.event; }
            code = (e.keyCode ? e.keyCode : e.which); 
            //console.log(code);
            if (e.altKey == true)
                return (true);

            if (e.ctrlKey == true)
                return (true);

            if (e.shiftKey == true)
                return (true);

            if (code == keycode) {
                func($this);
            }
        });
    }
    
    function bindHotkey($el, combo, handler) {
        const want = Object.assign({
            key: 'p',
            alt: false,
            ctrl: false,
            shift: false,
            leftAltOnly: false,
            rightAltOnly: false,
            prevent: true,
            stop: false
        }, combo);

        $el.on('keydown', function (e) {
            // 鍵位判斷：優先用 code
            const hitKey =
                (e.code === ('Key' + want.key.toUpperCase())) ||
                (e.key && e.key.toLowerCase() === want.key.toLowerCase()) ||
                (e.keyCode === want.key.toUpperCase().charCodeAt(0));

            if (!hitKey) return;

            // === 重點：Alt / AltGr 一起視為 Alt ===
            const altLike = e.altKey || e.getModifierState?.('AltGraph') === true || (e.location === 2 && e.ctrlKey);

            if (want.alt   && !altLike)   return;
            if (want.ctrl  && !e.ctrlKey) return;
            if (want.shift && !e.shiftKey) return;

            // 左/右 Alt 僅限（有需要才啟用）
            if (want.leftAltOnly && !(altLike && e.location === 1 && !e.ctrlKey && !e.getModifierState?.('AltGraph'))) return;
            if (want.rightAltOnly) {
                const isRightAlt = altLike && (e.location === 2 || e.getModifierState?.('AltGraph') === true);
                if (!isRightAlt) return;
            }

            if (want.prevent) e.preventDefault();
            if (want.stop) e.stopPropagation();
            handler(e, $el);
        });
    }

