    function sys_merge_procedure() {
        $j.blockUI({ message: "<h1><img src='../img/busy.gif' /> 請稍候...</h1>" });
        setTimeout(function(){
            var table_name = $j('#display_merge').attr('table_name');
            var key_name = $j('#display_merge').attr('key_name');
            var key_value_a = $j('#display_merge').attr('key_value_a');
            var info_a = $j('#display_merge').attr('info_a');
            var key_value_b = $j('#display_merge').attr('key_value_b');
