    function sys_search_dt_row(dt , arr_field , arr_value) {
        
        for (var row = 0; row < dt.MaxRow(); row++) {
            var row_flag = 1;

            for (var i = 0; i < arr_field.length; i++) {
                var str_field = arr_field[i];
                var str_value = arr_value[i];

                if (dt.getValueByRow(row , str_field) != str_value) {
                    row_flag = 0;
                    break;
                }
            }
            
            if (row_flag == 1) {
                return (row);
            }
        }

        return (-1);
    }

    function dt_focus_record(dt , fieldname , fieldvalue , datagrid_id) {
            var str_search_like = get_element_value('ele_search_like');
            with (dt) {
                for (var row = 0; row < MaxRow(); row++) {
//                    var fieldname = get_element_value('ele_search_kind');
                    var str_value = getValueByRow(row , fieldname);

                    //if ( str_value.toUpperCase().trim() == fieldvalue.toUpperCase().trim() )
                    var flg = false;

                    if (str_search_like == '1') {
                        if (str_value.toUpperCase().trim().indexOf(fieldvalue.toUpperCase().trim()) == 0)
                            flg = true;
                    }
                    else
                    {
                        if (str_value.toUpperCase().trim().indexOf(fieldvalue.toUpperCase().trim()) >= 0)
                            flg = true;
                    }

                    if ( flg == true )
                    {   
                        var $tr = $j($j(datagrid_id).find("tbody").find("tr")[row]);
                        //alert(row);
                        $tr.click();

                        break;
                    }
                }
            }

    }

    function setMonth($this) {
