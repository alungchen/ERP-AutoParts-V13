	    if (chk_browser("FireFox") == true)
	        return (get_mouse_point());
	
		var point = new Array();
		var e = window.event;
		
		if (e)
		{ 
			if (e.pageX || e.pageY)
			{
				point.push(e.pageX);
				point.push(e.pageY);
			}
			else if (e.clientX || e.clientY)
			{
				point.push(e.clientX + document.body.scrollLeft);
				point.push(e.clientY + document.body.scrollTop);
			}
		}
		
	    if (point[0] < 10)
	        point[0] = 10;

	    if (point[1] < 10)
	        point[1] = 10;
		
		return (point);
