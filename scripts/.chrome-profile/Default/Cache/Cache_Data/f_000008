    var temp = 0;
    var total = 0;
    
    if(sid=="")
        return (false);
    else if(!sid.match(/^\d{8}$/))
        return (false);
    else
    {
        for(var i = 0; i < tbNum.length ;i ++)
        {
            temp = sid.charAt(i) * tbNum[i];
            total += Math.floor(temp/10)+temp%10;
        }
        
        if(total%10==0 || (total%10==9 && sid.charAt(6)==7))
            return (true);
        else
            return (false);
    }
}

