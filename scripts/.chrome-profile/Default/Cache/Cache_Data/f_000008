            var related_target_name = $j('#display_merge').attr('related_target_name');
            var sp = $j('#display_merge').attr('sp');
            var anti_sp = $j('#display_merge').attr('anti_sp');
        
            var dt = sys_merge_master_create(table_name, key_name, key_value_a, info_a, key_value_b, info_b, related_table, related_key_name, related_target_name, sp, anti_sp);

            if (dt.getValue('flg_error') == '1') {
                alert("sys_merge_master_create " + dt.getValue("message"));
                $j.unblockUI();
                return (false);
            }

            var dt_detail = sys_merge_detail_create(dt.getValue('id'));

            if (dt_detail.getValue('flg_error') == '1') {
                alert("sys_merge_detail_create " + dt_detail.getValue("message"));
                $j.unblockUI();
                return (false);
            }

            var result = sys_merge_data_start(dt.getValue('id'));

            var dt_merge_amount = sys_merge_零件庫存金額(key_value_a , key_value_b);

            if (dt_merge_amount.getValue("flg_error") == "1") {
                alert(dt_merge_amount.getValue("message"));
            }

            do_search();

            alert(result);
            $j.unblockUI();
        }, 500);
    }

