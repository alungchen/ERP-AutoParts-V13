        url = url.rp('%customer_flag%', escape(str_customer_flag));
        url = url.rp('%supplier_flag%', escape(str_supplier_flag));
        url = url.rp('%store_no%', escape(str_store_no));
        //console.log("url = " + url);
        $iframe.attr('src' , url);

        //ShowMenu_upper($target, 'product_info');
        //showdiv(i_top, 'product_info', 'right');
