		tmp += "Content-Disposition: form-data; name=\"" + _field + "\"" + this.CRLF;
		tmp += "Content-Transfer-Encoding: binary" + this.CRLF + this.CRLF;
		tmp += _value + this.CRLF;
		tmp += "--" + this._boundary + this.CRLF;
		return tmp;
	}

