    function SortObjectInfo(list, SortName, SortType) {
        var new_field_value = new Array();
        var sort_list = new Array();

        for (var row = 0; row < list.length; row++) {
            var row_data = list[row];
            var col_value = "" + row_data[SortName];

            if (row == 0) {
                new_field_value.push(row_data);
                sort_list.push(col_value);
            }
            else {
                var flg_insert = 0;

                for (var i = 0; i < sort_list.length; i++) {
                    var new_col_value = "" + sort_list[i];
                    //console.log("new_col_value", new_col_value);
                    if (SortType == "ASC")
                        if (new_col_value > col_value)
                            flg_insert = 1;

                    if (SortType == "DESC")
                        if (new_col_value < col_value)
                            flg_insert = 1;

                    if (flg_insert == 1) {
                        new_field_value.splice(i, 0, row_data);
                        sort_list.splice(i, 0, col_value);
                        break;
                    }
                }

                if (flg_insert == 0) {
                    new_field_value.push(row_data);
                    sort_list.push(col_value);
                }
            }
        }

        return (new_field_value);
    }

