    function check_accdate(str_id) {

        var str_url = "/car2009/api/check_accdate_async/";
        var dt = null;
        var str_accdate = "";
        var ThisDate = $j("#ele_交易日期").val();
        var iDate = new Date(ThisDate);

        $j.ajax(
            {
                url: str_url
                , cache: false
                , global: false
                , type: "POST"
                , data: {
                    "id": str_id
                }
                , dataType: "json"
                , async: true
                , success: function (info) {
                    //console.log("api/check_accdate_async/", info);

                    if (info.Code != '0') {
                        alertify.error(info.Message);
                        return (false);
                    }

                    str_accdate = info.ReturnValue.accdate;

                    //console.log(str_accdate);

                    if (str_accdate == "0")
                        return (true);

                    //console.log("iDate.toFormat('yyyy-mm-dd').Right(2)=" + iDate.toFormat("yyyy-mm-dd").Right(2));
                    if (parseInt(iDate.toFormat("yyyy-mm-dd").Right(2)) > parseInt(str_accdate)) {
                        iDate = new Date(iDate.toFormat("yyyy-mm-01"));
                        iDate = iDate.DateAdd('m', 1);
                        //console.log("iDate.DateAdd('m', 1)=" + iDate.toFormat("yyyy-mm-dd"));
                        ThisDate = iDate.toFormat("yyyy-mm-01");
                        //console.log("ThisDate=" + ThisDate);
                        $j("#ele_結帳日期").val(ThisDate);

                        $j("#ele_結帳日期").trigger("change");

                        alertify.success("自動下月帳...");
                    }

                }
            }
        )

    }

