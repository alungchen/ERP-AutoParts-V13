                if (dt.MaxRow() == 0)
                    alertify.error("排序內容 不存在!!!");

            }
        }
    }

    function ToJsonArray(dt_data) {
        var arr = new Array();

        with (dt_data) {
            for (var row = 0; row < MaxRow(); row++) {
                var info = {};
                for (var col = 0; col < getFieldCount(); col++) {
                    var name = getFieldName(col);
                    var value = getValueByRow(row, name);

                    info[name] = value;
                }

                arr.push(info);
            }
        }

        return (arr);
    }

