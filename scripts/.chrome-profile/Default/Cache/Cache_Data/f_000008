    function DataRepeater(list, data_template) {
        var result = new Array();
        for (var i = 0; i < list.length; i++) {
            var info = list[i];
            var template = data_template;
            for (var name in info) {
                var value = "";
                try { value = "" + info[name]; }
                catch (e) { }
                if (typeof (info[name]) == "object") {
                    value = JSON.stringify(info[name]);
                }
                template = template.rp("{" + name + "}", value);
            }
            result.push(template);
        }
        return (result.join(""));
    }

    function DataAppender($dsp, list, data_template) {
        for (var i = 0; i < list.length; i++) {
            var iRow = i + 1;
            var info = list[i];
            var template = data_template;

            template = template.rp("{row}", "" + iRow);

            for (var name in info) {
                var value = "";

                if (info[name] == null)
                    info[name] = "";

                try { value = "" + info[name]; }
                catch (e) { }

                if (typeof (info[name]) == "object") {
                    value = JSON.stringify(info[name]);
                }

                template = template.rp("{" + name + "}", value);
            }

            $dsp.append(template)
        }
    }

