		this.drag_object_name = obj_name;
		this.set_mouse_point();

		if (this_zIndex <= max_zIndex)
			$j(this.target_name).style.zIndex = max_zIndex + 1;

		this.old_onmousedown = $j(this.drag_trigger_name).onmousedown;
		
