    function show_product_info($target, i_top)
    {
        //var $target = $j('#DataGridDetail tbody .ui-state-active');
        var $iframe = $j('#iframe_product_info');
        var url = $iframe.attr('attr_url');
        var status = $iframe.attr('attr_status');
