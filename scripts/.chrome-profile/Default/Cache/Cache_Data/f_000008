        var str_store_no = $j("#btn_preprice_store_no").attr("store_no");
        var show_btn_detail = $iframe.attr('attr_show_btn_detail');
        var show_btn_partkey = $iframe.attr('attr_show_btn_partkey');
        var show_btn_preprice = $iframe.attr('attr_show_btn_preprice');
        var old_property = "" + $iframe.attr("old_property");
        var property = {};

        property["url"] = url;
        property["status"] = status;
        property["partsid"] = partsid;
        property["top_num"] = top_num;
        property["customer_flag"] = str_customer_flag;
        property["supplier_flag"] = str_supplier_flag;
