    function stock_place_info($ele, only_default_store) {

        //console.log("function stock_place_info start", $ele, only_default_store, new Date());
        
        var arr_partsid = new Array();
        var str_arr_partsid = '';

        $ele.each(function(){
            var $this = $j(this);
            var partsid = $this.attr('attr_partsid');

            arr_partsid.push(partsid);

        });

        //console.log("stock_place_info - arr_partsid", arr_partsid);

        if (arr_partsid.length == 0)
            return (true);

        str_arr_partsid = arr_partsid.join(',');

        var str_url = '/car2009/api/stock_place_info/?arr_partsid=%arr_partsid%&only_default_store=%only_default_store%'
        var dt_stock_place = null;

        str_url = str_url.rp('%arr_partsid%', escape(str_arr_partsid));
        str_url = str_url.rp('%only_default_store%', escape(only_default_store));

        //console.log("dt_stock_place = get_data(str_url, '') start", str_url, new Date());
        var dt_stock_place = get_data(str_url, '');
        //console.log("dt_stock_place = get_data(str_url, '') finish", ToJsonArray(dt_stock_place), new Date());
        //console.log(dt_stock_place.ExportCSV());

        var fields = new Array();

        if ($ele.length > 0) {
            var check_template = $j($ele[0]).attr('attr_template');
            for (var col = 0; col < dt_stock_place.getFieldCount(); col++) {
                var name = dt_stock_place.getFieldName(col);

                if (check_template.indexOf("{" + name + "}") != -1) {
                    fields.push(name);
                }
            }
        }
        
        //console.log("fields.length", fields.length);
        //console.log("$ele.each start", new Date());
        $ele.each(function () {
            var $this = $j(this);
            var partsid = $this.attr('attr_partsid');
            //var dt = new DataTable();
            var dt = dt_stock_place.getSearchDataTable("零件主檔ID", partsid);
            var result = new Array();

            if (partsid == "") {
                return (true);
            }
            //console.log("partsid", partsid, $this);
            //console.log("dt", ToJsonArray(dt));
            $this.html("");

            for (var row = 0; row < dt.MaxRow(); row++) {
                var template = $this.attr('attr_template');

                for (var i = 0; i < fields.length; i++) {
                    var value = dt.getValueByRow(row, fields[i]);

                    template = template.rp('{' + fields[i] + '}', value);
                }
                //console.log(template);
                //$this.find("div").first().append(template);
                $this.append(template);
                result.push(template);
            }

            //console.log("resule = " + result.join(""));

            $this.attr("title", result.join(""));
        });
        //console.log("$ele.each finish", new Date());
    }

    function sys_preprice($ele , str_對象_type, func)
    {
        var str_對象ID = $j('#ele_對象ID').val();

        if (str_對象ID == '') {
            return (new DataTable());
        }
        var arr_partsid = new Array();
        var str_arr_partsid = '';

        $ele.each(function(){
            var $this = $j(this);
            var partsid = $this.attr('attr_partsid');

            arr_partsid.push(partsid);

        });

        if (arr_partsid.length == 0)
            return (true);

        str_arr_partsid = arr_partsid.join(',');

        var str_url = '';
        var dt_preprice = null;

        switch (str_對象_type) {
            case 'SUP':
                str_url = '../api/preprice_sup/?arr_partsid=%arr_partsid%&對象ID=%對象ID%';
                break;
            case 'CUS':
                str_url = '../api/preprice_cus/?arr_partsid=%arr_partsid%&對象ID=%對象ID%';
                break;

        }

        str_url = str_url.rp('%arr_partsid%', escape(str_arr_partsid));
        str_url = str_url.rp('%對象ID%', escape(str_對象ID));

        dt_preprice = get_data(str_url, '');

        $ele.each(function () {
            var $this = $j(this);
            var partsid = $this.attr('attr_partsid');
            var dt = dt_preprice.getSearchDataTable('零件主檔ID', partsid);
            var fields = new Array();

            for (var col = 0; col < dt.getFieldCount(); col++) {
                var name = dt.getFieldName(col);

                fields.push(name);
            }

            for (var row = 0; row < dt.MaxRow(); row++) {
                var template = $this.attr('attr_template');

                for (var i = 0; i < fields.length; i++) {
                    var value = dt.getValueByRow(row, fields[i]);

                    template = template.rp('{' + fields[i] + '}', value);

                }

                $this.find("div").first().append(template);
            }

            if (typeof (func) == "function") {
                func($this);
            }
        });
        //console.log("dt_preprice", ToJsonArray(dt_preprice));
        return (dt_preprice);
    }

