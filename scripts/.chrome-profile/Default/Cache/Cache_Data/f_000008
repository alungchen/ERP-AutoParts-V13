    function text_data_to_JsonArray(data) {
        console.log("text_data_to_JsonArray", data);
        var row_data = data.split("\n");
        var fields = row_data[0].split("\t");
        var list = new Array();
        console.log("row_data.length = ", row_data.length);
        console.log("fields.length = ", fields);
        for (var i = 0; i < row_data.length; i++) {
            row_data[i] = row_data[i].rp("\r", "");
        }

        for (var i = 0; i < fields.length; i++) {
            fields[i] = fields[i].rp(" ", "");
        }

        for (var i = 1; i < row_data.length; i++) {
            var col_data = row_data[i].split("\t");
