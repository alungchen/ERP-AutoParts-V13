if (isUndefined(Date.prototype.newDate) == true) {
	Date.prototype.newDate = function (str) {
		var str_split = "";
		var str_date = "";
		var str_result = "";
		
		if (str.indexOf("-") != -1)
		    str_split = "-";
		
		if (str.indexOf("/") != -1)
		    str_split = "/";

		if (str_split == "")
		    return (this.newDateNumber(str));
		    
		str_date = str.split(str_split);
		
		for (var i = 0; i < str_date.length; i++)
		{
		    if (isNumeric(str_date[i]) == false)
		        return (new Date());
		}
		
		if (str_date.length != 3)
		    return (new Date());
		
		str_result = str_date[0] + "/" + str_date[1] + "/" + str_date[2];
		
		if (isDate(str_result) == false)
		    return (new Date());
		return (new Date(str_result));
	};
}

