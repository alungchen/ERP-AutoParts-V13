        var $text = $j("#" + input_id);
        
        
        if ($div.length == 0)
        {
            $div = $j("<div></div>");
            $div.attr("id" , div_id)
                .css("display", "none");
            $body.append( $div );
            
        }
        
        if ($text.length == 0)
        {
            $text = $j("<input />");
            $text.attr("type" , "text")
                .attr("id" , input_id);
            $div.append( $text );
        }
        
        $text.autocomplete({
		    source: str_url
		    
	    });           
	    
	    $text.keydown(function (e) { 
            var $ele = $j("#" + $j(this).attr("ElementName"));
            
            if (window.event) { e = window.event; }
            code = (e.keyCode ? e.keyCode : e.which); 
            
            switch (code)
