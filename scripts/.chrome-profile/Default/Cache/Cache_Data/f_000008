//            return(false);

        if (search_content == "") {
            $j('#display_DataGridDetail tbody tr:eq(0)').click().find('input:text:eq(0)').focus();

            return (false);
        }
        
        var dt = dt_detail.getSearchDataTable(index_name, search_content, "Like","string");
        
        if (dt.MaxRow() != 0) {
