    var id = "";
    var arr_url = null;
    //console.log("do_label2:" + id_list.join(","));
    //console.log("do_label2:", ModuleName);
    if (id_list.length == 0) {
        alert("沒有資料被選到,請在左邊方塊勾選。");
        return (false);
    }
    //console.log("set_temp_data");
    id = set_temp_data(id_list);
    //console.log("id = " + id);
    if (id == "") {
        alert("set_temp_data:資料暫存錯誤!!! ");
        return("");
    }

    str_url = str_url.rp("%KeyName%", escape(KeyName));
    str_url = str_url.rp("%id%", escape(id));
    str_url = str_url.rp("%ViewName%", escape(ViewName));
    str_url = str_url.rp("%ModuleName%", escape(ModuleName));
    str_url = str_url.rp("%ReportName%", escape(ReportName));
    str_url = str_url.rp("%FieldList%", escape(FieldList));
    //console.log(str_url);

    arr_url = str_url.split("?");
    //console.log("HttpGet_HttpPost_Save");
    id = HttpGet_HttpPost_Save(arr_url[0] , arr_url[1]);
    //console.log(id);
    if (id == "")
        return(false);

    //console.log("HttpGet_HttpPost_Read: " + HttpGet_HttpPost_Read(id));

    var $dialog_label = $j("#dialog_label");

    if ($dialog_label.length == 0) {
        var $iframe = $j("<iframe></iframe>");
        $dialog_label = $j("<div></div>");
        $dialog_label.attr("id", "dialog_label");
        $iframe.attr("id", "iframe_label");
        $dialog_label.append($iframe);
        $j("body").append($dialog_label);

    }

    var $iframe = $j("#iframe_label");

    $iframe.attr("width", "100%");
    $iframe.attr("height", "100%");
    $iframe.attr("frameborder", "0");
    $iframe.attr("src", HttpGet_HttpPost_Read(id));

    $j("#dialog_label").dialog({
        modal: true
			, title: "標籤列印"
			, width: 1200
			, height: 800
			, buttons: {
			    "Ok": function () {
			        $j(this).dialog("close");
			    }

			}
    });


}

