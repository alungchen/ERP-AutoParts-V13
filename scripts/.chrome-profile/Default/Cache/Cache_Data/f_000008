function InitButtonHighLight($target) {
    $target.focus(function(){
        var $this = $j(this);
        //console.log($this.val() + " focus");
        ButtonHighLight($this, 500);

    });

    $target.blur(function(){
        var $this = $j(this);
        //console.log($this.val() + " blur");
        ClearButtonHighLight($this);
        
    });
}

function ButtonHighLight($target, i_delay)
{
    var iTimeout = 0;
    if ($target.hasClass('high-Light')) {
        $target.addClass('no-high-Light');
        $target.removeClass('high-Light');
    }
    else {
        $target.addClass('high-Light');
        $target.removeClass('no-high-Light');
    }

    iTimeout = setTimeout(function () { ButtonHighLight($target, i_delay); }, i_delay);
    $target.attr("iTimeout", iTimeout);
    //console.log($target.val() + " " + iTimeout);
}

function ClearButtonHighLight($target)
{
    var iTimeout = parseInt($target.attr("iTimeout"));
    $target.removeClass('high-Light');
    $target.removeClass('no-high-Light');
    clearTimeout(iTimeout);
    //console.log($target.val() + " " + iTimeout);
}

