    function GetOptionList(dt_data, ValueName, LabelName) {
        var result = "";

        with (dt_data) {
            for (var row = 0; row < MaxRow(); row++) {
                var str = "<option value='{value}'>{label}</option>";
                var value = getValueByRow(row, ValueName);
                var label = getValueByRow(row, LabelName);

                str = str.rp("{value}", value);
                str = str.rp("{label}", label);

                result += str;
            }
        }

        return (result);
    }
    
