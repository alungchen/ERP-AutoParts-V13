            return (false);
        else
            $iframe.attr("old_property", JSON.stringify(property));

        //console.log(property + "  " + new Date().toFormat("yyyy-mm-dd hh:nn:dd"));

        if (typeof(status) == 'undefined' || typeof(url) == 'undefined')
            return true;

        if (status == '0') {
            $j('#product_info').hide();
            return true;
        }

