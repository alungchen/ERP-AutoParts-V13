    var _ele = str_ele.split(",");
    var send_data = new Array();
    var str_send_data = "";
    var str_result = "";
    var dt_param = url_to_post_data(str_url);
    var strPageName = dt_param.getValueByIndex("Name", "PageName", "Value");
    
    with (dt_field)
    {
        create("FieldName,FieldValue".split(","), null, 0);
        
        AddNewRow();
        setValueByRow(MaxRow()-1, "FieldName", "AjaxCall");
        setValueByRow(MaxRow()-1, "FieldValue", "AjaxCall");
        
        for (var i = 0; i < _ele.length; i++)
        {
            AddNewRow();
            setValueByRow(MaxRow()-1, "FieldName", _ele[i]);
            setValueByRow(MaxRow()-1, "FieldValue", get_element_value(_ele[i]));
        }
        
        for (var row = 0; row < dt_param.MaxRow(); row++)
        {
            if (dt_param.getValueByRow(row, "Name") == "PageName")
                continue;
        
            AddNewRow();
            setValueByRow(MaxRow()-1, "FieldName", dt_param.getValueByRow(row, "Name"));
            setValueByRow(MaxRow()-1, "FieldValue", dt_param.getValueByRow(row, "Value"));
        }
        
        for (var row = 0; row < MaxRow(); row++)
        {
            var str = "%FieldName% : %FieldValue%";
            var str_name = getValueByRow(row, "FieldName");
            var str_value = getValueByRow(row, "FieldValue");
            
            if (str_name.trim() == "")
                continue;
            
            str = str.ReplaceAll("%FieldName%", str_name);
            str = str.ReplaceAll("%FieldValue%", toJSString(str_value));
            
            send_data.push(str)
        }
    }
    
    str_send_data = "var str_json_obj = {\n" + send_data.join("\n, ") + "\n}";
    //alert(str_send_data);
    eval(str_send_data)
    
    str_result = $j.ajax(
        {
        url : strPageName
        , cache: false
        , global : false
        , type : "POST"
        , data : str_json_obj
        , dataType : "text"
        , async : false
        , success : function(data) {}
        }
    ).responseText;
        
    return (str_result)
}



function toJSString(str) {
    str = "" + str;
    var line_list = str.split('\n');
    var tmp = "";
    var str_result = new Array();
    
    for (var i = 0; i < line_list.length; i++)
    {
        tmp = "" + line_list[i];
        
        tmp = tmp.ReplaceAll("\r", "");
        tmp = tmp.ReplaceAll("\n", "");
        
        
        tmp = tmp.replace(/\\/g, "\\\\");
        tmp = tmp.replace(/\"/g, "\\\"");
        
        str_result.push(tmp);
    }
    
    return ("\"" + str_result.join("\"" + "\r\n" + " + \"\\r\\n") + "\"");
}

