    function sys_date_plus($target , date_unittype , date_add , date_format) {
        var str_value = $target.val();
        
        str_value = str_value.ReplaceAll('-' , '/');
        if (str_value.length == 7) {
            str_value = str_value + '/01';

            var thisdate = new Date(str_value);
        
            thisdate = thisdate.DateAdd( date_unittype , date_add );
        
            thisdate = thisdate.toFormat( date_format );
            //alert(plusdate);
            //thisdate = thisdate.ReplaceAll('/' , '-');

            $target.trigger('focus');
            $target.val(thisdate);
            $target.trigger('blur');
        }
    }

