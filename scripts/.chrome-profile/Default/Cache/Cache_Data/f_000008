function AppendData(dt_data, str_data_template, $dsp, iPageIndex, iPageSize)
{
	var iStartRow = 0;
	var iMaxRow = 10;

	if (dt_data.MaxRow() == 0)
	    return (false);

	if (typeof(iPageIndex) == "undefined" || typeof(iPageSize) == "undefined")
	{
		iPageIndex = 0;
		iPageSize = dt_data.MaxRow();
	}
	
	iStartRow = iPageIndex * iPageSize;
	iMaxRow = iStartRow + iPageSize;

	if (iMaxRow > dt_data.MaxRow())
		iMaxRow = dt_data.MaxRow();
		
	with (dt_data)
	{
		for (var row = iStartRow; row < iMaxRow; row++)
		{
			var str_template = str_data_template

			str_template = str_template.ReplaceAll("%row%", (row+1));
			for (var col = 0; col < getFieldCount(); col++)
			{
				var name = getFieldName(col);
				var value = getValueByRow(row, name);
				
				str_template = str_template.ReplaceAll("%" + name + "%", value);
			}
			
			$dsp.append(str_template);
		}
	}
}

