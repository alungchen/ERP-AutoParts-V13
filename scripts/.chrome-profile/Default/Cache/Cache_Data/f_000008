		}
		
		document.onmouseup = function ()
		{
			this_class.drop();
			return (false);
		}
		
		$j(this.drag_trigger_name).onmousedown = function ()
		{
			return (false);
		}
		
		if (this.on_grab() == false)
			return (false);
			
		if (this.after_grab() == false)
			return (false);
		
		return (false);
	}

	this.drop = function ()
	{
		if (this.before_drop() == false)
			return (false);
	
		try
		{
			this.drag_object_name = "";
			$j(this.drag_trigger_name).onmousedown = this.old_onmousedown;
