    // 通用拖曳功能封裝
    function enableDrag(targetSelector, handleSelector) {
        const target = document.querySelector(targetSelector);
        const handle = document.querySelector(handleSelector);
        let isDragging = false;
        let offsetX = 0;
        let offsetY = 0;

        // 設定游標樣式
        handle.addEventListener("mouseover", () => handle.style.cursor = "pointer");
        handle.addEventListener("mouseout", () => handle.style.cursor = "default");

        // 開始拖曳
        handle.addEventListener("mousedown", (event) => {
            isDragging = true;
            offsetX = event.clientX - target.offsetLeft;
            offsetY = event.clientY - target.offsetTop;
            target.classList.add("grabbing");
        });

        // 拖曳過程
        document.addEventListener("mousemove", (event) => {
            if (isDragging) {
                target.style.left = `${event.clientX - offsetX}px`;
                target.style.top = `${event.clientY - offsetY}px`;
            }
        });

        // 結束拖曳
        document.addEventListener("mouseup", () => {
            if (isDragging) {
                isDragging = false;
                target.classList.remove("grabbing");
            }
        });
    }

