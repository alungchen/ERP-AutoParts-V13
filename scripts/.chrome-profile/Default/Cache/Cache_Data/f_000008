this.getSearchDataTable = function (index_name, index_value, _type, _value_type) {
        var i_name = this.SearchFieldName(index_name);
        var _field_name = new Array();
        var _field_type = new Array();
        var _data_table = new Array();
        var _dt = new DataTable();
 
        if (i_name == -1)
            return (_dt);
 
        for (var col = 0; col < this._FieldName.length; col++) {
            _field_name.push(this._FieldName[col]);
            _field_type.push(this._FieldType[col]);
        }
 
        for (var row = 0; row < this.MaxRow(); row++) {
            var _data_row = this._FieldValue[row];
            var i_value1 = _data_row[i_name].toUpperCase();
            var i_value2 = index_value.toUpperCase();
            var flg_find = false;
 
 
            try {
                switch (_value_type) {
                    case "int":
                        i_value1 = parseInt(i_value1);
                        i_value2 = parseInt(i_value2);
                        break;
 
                    case "float":
                        i_value1 = parseFloat(i_value1);
                        i_value2 = parseFloat(i_value2);
                        break;
 
                    case "string":
                    default:
                        break;
                }
            } catch (e) { window.status = e.Message; }
 
 
            try { _type = _type.toUpperCase(); } catch (e) { }
 
            switch (_type) {
                case "Like".toUpperCase():
                    if (i_value1.indexOf(i_value2) != -1)
                        flg_find = true;
                    break;
 
                case "Not Like".toUpperCase():
                    if (i_value1.indexOf(i_value2) == -1)
                        flg_find = true;
                    break;
 
                case "<>":
                    if (i_value1 != i_value2)
                        flg_find = true;
 
                case ">":
                    if (i_value1 > i_value2)
                        flg_find = true;
                    break;
 
                case ">=":
                    if (i_value1 >= i_value2)
                        flg_find = true;
                    break;
 
                case "<":
                    if (i_value1 < i_value2)
                        flg_find = true;
                    break;
 
                case "<=":
                    if (i_value1 <= i_value2)
                        flg_find = true;
                    break;
 
                default:
                    if (i_value1 == i_value2)
                        flg_find = true;
                    break;
            }
 
            if (flg_find == true) {
                var _new_data_row = new Array();
 
                for (var col = 0; col < _data_row.length; col++)
                    _new_data_row.push(_data_row[col]);
 
                _data_table.push(_new_data_row);
            }
        }
 
        _dt.setFieldName(_field_name);
        _dt.setFieldType(_field_type);
        _dt.setFieldValue(_data_table);
 
        return (_dt);
    }
    	
