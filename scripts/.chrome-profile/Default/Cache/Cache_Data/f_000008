    function Schema_attr(dt_Schema , TableID)
    {
        var $table = $j(TableID);
        var $input = $table.find("input:text");
        
        $input.each(function (row, obj) {
            var $this = $j(this);
            var FieldName = $this.attr("FieldName");
            var Max_Length = dt_Schema.getValueByIndex("COLUMN_NAME" , FieldName , "CHARACTER_MAXIMUM_LENGTH");
            var data_type = dt_Schema.getValueByIndex("COLUMN_NAME" , FieldName , "DATA_TYPE");
 
            if (parseInt(Max_Length) > 80)
                Max_Length = "80";

            switch (data_type)
            {
                case "nvarchar":
                    if (Max_Length != "-1") {
                        $this.attr("maxlength" , Max_Length);
                        $this.attr("size" , Max_Length);
                    }
                    else
                        $this.attr("size" , "80");
                        
                    break;
                    
                default:
                    break;                    
            }
            
            $this.attr("datatype" , data_type);            
            
        });
    }
    
