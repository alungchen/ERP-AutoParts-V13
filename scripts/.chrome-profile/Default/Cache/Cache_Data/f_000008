    function alertify_event() {
        $j('body').keydown(function (e) {

            switch (e.target.id) {
                case "alertify-cancel":
                    switch (e.keyCode) {
                        case 37:
                            $j('#alertify-ok').focus();
                            break;
                        case 38:
                            $j('#alertify-ok').focus();
                            break;
                        case 39:
                            $j('#alertify-ok').focus();
                            break;
                        case 40:
                            $j('#alertify-ok').focus();
                            break;
                        case 67:
                            $j('#alertify-cancel').click();
                            break;
                        case 79:
                            $j('#alertify-ok').click();
                            break;

                    }
                    break;

                case "alertify-ok":
                    switch (e.keyCode) {
                        case 37:
                            $j('#alertify-cancel').focus();
                            break;
                        case 38:
                            $j('#alertify-cancel').focus();
                            break;
