        else
            $j('.show_btn_detail').hide();

        if (show_btn_partkey == '1')
            $j('.show_btn_partkey').show();
        else
            $j('.show_btn_partkey').hide();

        if (show_btn_preprice == '1')
            $j('.show_btn_preprice').show();
        else
            $j('.show_btn_preprice').hide();


